    bracket = session.get('bracket',{})
    stage_order = ['r32','r16','qf','sf','final']
    stage_names = {'r32':'Round of 32','r16':'Round of 16','qf':'Quarter-Finals','sf':'Semi-Finals','final':'THE FINAL'}
    step_labels = ['Group Stage','Round of 32','Round of 16','Quarters','Semis','Final']
    stage_steps = {'r32':1,'r16':2,'qf':3,'sf':4,'final':5}

    matches = bracket[stage]
    total = len(matches)

    if request.method == 'POST':
        hg = int(request.form.get('hg',0))
        ag = int(request.form.get('ag',0))
        # Handle draw with extra time - force a winner
        if hg == ag:
            # Default: home wins in ET (user can adjust)
            winner_choice = request.form.get('winner', matches[idx]['home'])
        else:
            winner_choice = matches[idx]['home'] if hg > ag else matches[idx]['away']

        matches[idx]['hg'] = hg
        matches[idx]['ag'] = ag
        matches[idx]['winner'] = winner_choice
        bracket[stage] = matches

        # Propagate winner to next round
        next_stage_map = {'r32':'r16','r16':'qf','qf':'sf','sf':'final'}
        if stage in next_stage_map:
            ns = next_stage_map[stage]
            nm = idx // 2
            if idx % 2 == 0:
                bracket[ns][nm]['home'] = winner_choice
            else:
                bracket[ns][nm]['away'] = winner_choice

        session['bracket'] = bracket

        if idx + 1 < total:
            return redirect(url_for('predict_bracket', stage=stage, idx=idx+1))
