def group_matches():
    matches = []
    for g, teams in GROUPS.items():
        pairs = [(teams[i],teams[j]) for i in range(4) for j in range(i+1,4)]
        for h,a in pairs:
            matches.append({'group':g,'home':h,'away':a})
    return matches

def calc_standings(group, results):
    teams = GROUPS[group]
    st = {t:{'pts':0,'gf':0,'ga':0,'gd':0,'w':0,'d':0,'l':0} for t in teams}
    for r in results:
        if r['group']!=group: continue
        h,a,hg,ag = r['home'],r['away'],r['hg'],r['ag']
        st[h]['gf']+=hg; st[h]['ga']+=ag; st[a]['gf']+=ag; st[a]['ga']+=hg
        if hg>ag: st[h]['pts']+=3; st[h]['w']+=1; st[a]['l']+=1
        elif hg<ag: st[a]['pts']+=3; st[a]['w']+=1; st[h]['l']+=1
        else: st[h]['pts']+=1; st[a]['pts']+=1; st[h]['d']+=1; st[a]['d']+=1
    for t in st: st[t]['gd']=st[t]['gf']-st[t]['ga']
    ranked = sorted(teams, key=lambda t:(-st[t]['pts'],-st[t]['gd'],-st[t]['gf']))
    return st, ranked

