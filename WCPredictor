@app.route('/build_bracket')
def build_bracket():
    results = session.get('results', [])
    qualifiers = {}
    for g in GROUPS:
        st, ranked = calc_standings(g, results)
        qualifiers[g] = ranked

    # R32: 16 matches. Winners: 1st, 2nd of each group
    # Classic WC R32 pairing
    r32 = [
        (qualifiers['A'][0], qualifiers['B'][1]),
        (qualifiers['C'][0], qualifiers['D'][1]),
        (qualifiers['E'][0], qualifiers['F'][1]),
        (qualifiers['G'][0], qualifiers['H'][1]),
        (qualifiers['B'][0], qualifiers['A'][1]),
        (qualifiers['D'][0], qualifiers['C'][1]),
        (qualifiers['F'][0], qualifiers['E'][1]),
        (qualifiers['H'][0], qualifiers['G'][1]),
    ]

    bracket = {
        'r32': [{'home':h,'away':a,'hg':None,'ag':None} for h,a in r32],
        'r16': [{'home':'TBD','away':'TBD','hg':None,'ag':None} for _ in range(8)],
        'qf':  [{'home':'TBD','away':'TBD','hg':None,'ag':None} for _ in range(4)],
        'sf':  [{'home':'TBD','away':'TBD','hg':None,'ag':None} for _ in range(2)],
        'final':[{'home':'TBD','away':'TBD','hg':None,'ag':None}],
    }
    session['bracket'] = bracket
    return redirect(url_for('predict_bracket', stage='r32', idx=0))

@app.route('/bracket/<stage>/<int:idx>', methods=['GET','POST'])
